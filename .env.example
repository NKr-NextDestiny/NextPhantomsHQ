# ===========================================
# NextPhantoms Environment Configuration
# ===========================================

# DATABASE
DB_USER=phantoms
DB_PASSWORD=changeme
DB_NAME=next_phantoms
DB_PORT=5432
DATABASE_URL=postgresql://phantoms:changeme@postgres:5432/next_phantoms

# JWT AUTH
JWT_SECRET=change-this-to-a-long-random-string
JWT_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=30d

# DISCORD OAUTH
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
DISCORD_CALLBACK_URL=http://localhost:4000/api/auth/discord/callback

# ACCESS CONTROL
# Required: Only members of this Discord server can log in
REQUIRED_GUILD_ID=
# Optional: Comma-separated Discord role IDs. Users with ANY of these roles can log in.
ALLOWED_ROLE_IDS=
# Optional: Comma-separated Discord role IDs that grant admin access in the app.
ADMIN_ROLE_IDS=
# Optional: Comma-separated Discord USER IDs that always get admin access.
# Useful for specific people who don't have an admin role.
# Find via: Rechtsklick auf User → "ID kopieren" (Entwicklermodus muss an sein)
ADMIN_USER_IDS=

# APP URLS
APP_URL=http://localhost:3000
API_URL=http://localhost:4000
NEXT_PUBLIC_API_URL=http://localhost:4000

# APP SETTINGS
DEFAULT_LANGUAGE=de
NODE_ENV=production

# FILE UPLOADS
UPLOAD_DIR=./uploads
MAX_FILE_SIZE_MB=50
# 64-character hex for AES-256-GCM file encryption at rest.
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
FILE_ENCRYPTION_KEY=

# RATE LIMITING
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# SMTP (for email notifications)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@nextphantoms.de

# DISCORD WEBHOOK (optional, for notifications)
DISCORD_WEBHOOK_URL=
